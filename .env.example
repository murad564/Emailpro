# ── Brevo (formerly Sendinblue) ──────────────────────────────────────────────
# Free tier: 300 emails/day, unlimited contacts
# Get your API key: https://app.brevo.com → Settings → API Keys → Create a new API key
BREVO_API_KEY=your-brevo-api-key-here

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for tracking pixel and click redirect URLs in emails
# Change to your production domain when deploying
NEXT_PUBLIC_APP_URL=http://localhost:3000
